{
  "name": "space-pad",
  "private": true,
  "scripts": {
    "dev:db": "docker compose up -d db",
    "dev:api": "npm run start:dev --prefix backend",
    "dev:web": "npm start --prefix frontend",
    "dev": "concurrently -k -n api,web -c green,magenta \"npm run dev:api\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
