# Image for local development with Docker bind mounts (see ../docker-compose.override.yml).
# Keeps devDependencies; no production prune — Nest runs with `start --watch`.

FROM node:22-bookworm-slim

WORKDIR /app

COPY package*.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./

RUN npm ci

COPY . .

RUN npx prisma generate

EXPOSE 3000

ENV NODE_ENV=development

CMD ["npm", "run", "start:dev"]
